# SLAra dashboard ‚Äî dev config template. Copy ke `.env.development` (gitignored).
#
# Phase 4: flow decide LIVE ke `agent` (M6). View lain masih fixture.
# Prasyarat: ai UP di :8000, lalu agent UP di :3000.
#   cd services/ai    && uv run uvicorn app.main:app --port 8000   # tunggu "Startup selesai"
#   cd services/agent && AI_BASE_URL=http://localhost:8000 npm start

# false => shipments/kpi/decide/resolve pakai backend nyata. true => semua fixture (offline).
VITE_USE_MOCK=false

# Base agent (M6) untuk fetch sisi SSR (Node butuh URL absolut). Di browser,
# app pakai path relatif /api/v1 yang di-proxy Vite ke origin ini (same-origin,
# hindari CORS). VITE_API_BASE_URL = nama lama, masih dihormati.
VITE_API_BASE=http://localhost:3000/api/v1

# Base ai service untuk Route Optimization (M4 tidak lewat agent). SSR only;
# browser pakai proxy /internal.
VITE_AI_BASE=http://localhost:8000

# Override origin proxy (opsional): AGENT_ORIGIN, AI_ORIGIN ‚Äî lihat vite.config.ts
