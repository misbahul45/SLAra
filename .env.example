# ==========================================
# SLAra — Root Environment (template, aman di-commit)
# Copy ke .env lalu isi nilai real. Semua service baca file ini via env_file: ../.env
# Semua database di bawah pakai CLOUD (bukan container lokal) — lihat catatan tiap section.
# ==========================================

# ----- Runtime -----
NODE_ENV=development

# ----- Service Ports (host) -----
GATEWAY_PORT=80
AGENT_PORT=3000
DATA_PORT=8081
AI_PORT=8000
APP_PORT=5173

# ----- MongoDB Atlas (Data service) -----
# Ambil dari Atlas dashboard > Connect > Drivers. Wajib pakai mongodb+srv:// (bukan mongodb://)
# dan sertakan user/password + nama cluster. Whitelist IP kamu (atau 0.0.0.0/0 utk dev) di Network Access.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=slara

# ----- Neo4j AuraDB Free (Data service) -----
# Ambil dari Aura console saat create instance (connection URI muncul sekali, simpan baik-baik).
# Wajib neo4j+s:// (TLS), BUKAN bolt://. Port tidak perlu ditulis (default 7687 lewat TLS).
# NEO4J_AUTH tidak lagi dipakai (itu khusus container lokal) — hapus/comment kalau tidak dipakai kode.
NEO4J_URI=neo4j+s://<xxxxxxxx>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<password-dari-aura>

# ----- Redis Cloud / Upstash (Data + Agent + AI) -----
# Redis Cloud: dari dashboard > Configuration > Public endpoint. Upstash: dari console > REST/TCP URL.
# Wajib rediss:// (TLS, huruf s di belakang), BUKAN redis://.
REDIS_URL=rediss://default:<password>@<endpoint>.redns.redis-cloud.com:<port>

# ----- Qdrant Cloud (Agent RAG) -----
# Dari Qdrant Cloud dashboard > cluster detail > Endpoint. Wajib https://, dan butuh API key terpisah.
QDRANT_URL=https://<xxxxxxxx>.<region>.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=<api-key-dari-qdrant-cloud>

# ----- Kafka Cloud (semua service) -----
# Pilih SATU provider (Upstash Kafka / Aiven / Confluent). Format di bawah contoh Upstash Kafka
# (SASL_SSL). Broker cloud SELALU butuh auth + TLS, beda dgn kafka:9092 lokal yang plaintext.
KAFKA_BROKERS=<xxxxxxxx>.upstash.io:9092
KAFKA_SASL_USERNAME=<username-dari-provider>
KAFKA_SASL_PASSWORD=<password-dari-provider>
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SECURITY_PROTOCOL=SASL_SSL

# ----- Frontend (apps/app) -----
# URL gateway yang dipanggil dashboard
VITE_API_BASE_URL=http://localhost/api