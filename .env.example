# ==========================================
# SLAra — Root Environment (template, aman di-commit)
# Copy ke .env lalu isi nilai real. Semua service baca file ini via env_file: ../.env
# ==========================================

# ----- Runtime -----
NODE_ENV=development

# ----- Service Ports (host) -----
GATEWAY_PORT=80
AGENT_PORT=3000
DATA_PORT=8081
AI_PORT=8000
APP_PORT=5173

# ----- MongoDB (Data service) -----
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=slara

# ----- Neo4j (Data service) -----
# Format NEO4J_AUTH: user/password
NEO4J_AUTH=neo4j/password
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ----- Redis (Data + Agent + AI) -----
REDIS_URL=redis://redis:6379

# ----- Qdrant (Agent RAG) -----
QDRANT_URL=http://qdrant:6333

# ----- Kafka (semua service) -----
KAFKA_BROKERS=kafka:9092

# ----- Frontend (apps/app) -----
# URL gateway yang dipanggil dashboard
VITE_API_BASE_URL=http://localhost/api
